[
  {
    "label": "ensure_remote_dir",
    "description": "Create remote directory for capture files",
    "order": 1,
    "command": "mkdir -p {remote_directory}",
    "sleep": 0
  },
  {
    "label": "delete_previous",
    "description": "Remove previous pcap files",
    "order": 2,
    "command": "rm -f {remote_directory}/*.pcap",
    "sleep": 1,
    "when": "delete_prev_pcap"
  },
  {
    "label": "start_tcpdump",
    "description": "Start tcpdump CSI capture",
    "order": 3,
    "command": "nohup /jffs/tcpdump -i {interface} dst port 5500 -w {full_remote_path} > /dev/null 2>&1 &",
    "sleep": 0
  },
  {
    "label": "wait_capture",
    "description": "Wait for capture duration",
    "order": 4,
    "sleep": "{capture_duration}"
  },
  {
    "label": "stop_tcpdump",
    "description": "Terminate tcpdump capture",
    "order": 5,
    "command": "killall tcpdump",
    "sleep": 0
  }
]
