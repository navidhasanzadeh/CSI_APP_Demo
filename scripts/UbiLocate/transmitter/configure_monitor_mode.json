[
  {
    "label": "interface_up",
    "description": "Bring interface up via wl",
    "order": 1,
    "command": "/usr/sbin/wl -i {interface} up",
    "sleep": 0
  },
  {
    "label": "radio_on",
    "description": "Enable radio",
    "order": 2,
    "command": "/usr/sbin/wl -i {interface} radio on",
    "sleep": 0
  },
  {
    "label": "set_country",
    "description": "Set country code",
    "order": 3,
    "command": "/usr/sbin/wl -i {interface} country UG",
    "sleep": 0
  },
  {
    "label": "set_channel",
    "description": "Configure chanspec",
    "order": 4,
    "command": "/usr/sbin/wl -i {interface} chanspec {channel}",
    "sleep": 0
  },
  {
    "label": "enable_monitor",
    "description": "Enable monitor mode",
    "order": 5,
    "command": "/usr/sbin/wl -i {interface} monitor 1",
    "sleep": 0
  },
  {
    "label": "ifconfig_up",
    "description": "Bring interface up via ifconfig",
    "order": 6,
    "command": "ifconfig {interface} up",
    "sleep": 0
  },
  {
    "label": "apply_nexutil_base",
    "description": "Apply nexutil configuration",
    "order": 7,
    "command": "cd /jffs/send_periodically; /jffs/send_periodically/nexutil -I {interface} -s500 -b -l34 -vm+IBEQGIAQD//wASNFYAAAAAAAAAAAAAAAAAAAAAAAAAA==",
    "sleep": 0
  },
  {
    "label": "set_shmem_172a",
    "description": "Configure shared memory 0x172a",
    "order": 8,
    "command": "wl -i {interface} shmem 0x172a 2",
    "sleep": 0
  },
  {
    "label": "set_shmem_172c",
    "description": "Configure shared memory 0x172c",
    "order": 9,
    "command": "wl -i {interface} shmem 0x172c 0",
    "sleep": 0
  },
  {
    "label": "txcore_config",
    "description": "Configure txcore",
    "order": 10,
    "command": "wl -i {interface} txcore -s 1 -c 1 -o 1 -k 1",
    "sleep": 0
  },
  {
    "label": "nexutil_trigger",
    "description": "Trigger nexutil CSI capture",
    "order": 11,
    "command": "cd /jffs/send_periodically; /jffs/send_periodically/nexutil -I{interface} -s528 -i -v15 -l 2",
    "sleep": 0
  },
  {
    "label": "set_shmem_1776",
    "description": "Configure shared memory 0x1776",
    "order": 12,
    "command": "wl -i {interface} shmem 0x1776 0x9000",
    "sleep": 0
  },
  {
    "label": "set_shmem_177e",
    "description": "Configure shared memory 0x177e",
    "order": 13,
    "command": "wl -i {interface} shmem 0x177e 0xf800",
    "sleep": 0
  }
]
